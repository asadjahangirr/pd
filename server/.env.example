# ------------------------------------------------------------------
# Template for server/.env — copy this file to ".env" and fill in real
# values. Do NOT put real secrets in this example file (it is committed).
# ------------------------------------------------------------------

# MongoDB Atlas database user + cluster details.
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_HOST=cluster0.xxxxx.mongodb.net
DB_NAME=delight_pharma

# Optional: a full connection string. If set, it overrides the parts above
# (handy for deployment). Leave it out for local development.
# MONGODB_URI=

# Admin auth (generate these with:  npm run setup:admin )
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=your_bcrypt_hash
JWT_SECRET=your_long_random_secret

# Cloudinary image hosting (one variable from the Cloudinary dashboard)
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# Email notifications (Gmail App Password) — optional
GMAIL_USER=youremail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
OWNER_EMAIL=youremail@gmail.com
STORE_NAME=Delight Pharma

# Port the API server listens on
PORT=5000
